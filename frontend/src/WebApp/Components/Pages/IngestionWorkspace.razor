@page "/ingestion/{StudyId}"
@page "/ingestion/{StudyId}/{ExecutionId}"
@rendermode InteractiveServer
@inject IngestionWorkspaceState WorkspaceState
@inject WorkspaceSectionState SectionState
@inject DatasetSeedCatalogService Catalog
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTransitionLoader Visible="_navigating" Blocking="true" Message="Returning to portfolio…" />

<div class="workspace-header">
    <a href="/" class="back-link" @onclick="GoHome" @onclick:preventDefault>← Portfolio</a>
    <PageMasthead Kicker="Ingestion"
                  Title="@(_studyTitle ?? StudyId)"
                  Subtitle="Ingestion & Translation → Metadata & Linking → Knowledge Curator → Vector DB">
        <LoadingButton IsLoading="WorkspaceState.IsBusy"
                       Disabled="!WorkspaceState.CanStartWorkflow"
                       OnClick="StartWorkflowAsync">
            Start ingestion workflow
        </LoadingButton>
    </PageMasthead>
</div>

@if (WorkspaceState.IsBusy && WorkspaceState.Progress is null)
{
    <LoadingBlock Message="Loading ingestion workspace…" />
}
else if (!string.IsNullOrWhiteSpace(WorkspaceState.Error))
{
    <ErrorState Message="@WorkspaceState.Error" OnRetry="ReloadAsync" />
}
else
{
    <WorkflowStatusBanner Progress="WorkspaceState.Progress" IsPolling="WorkspaceState.IsPolling" />

    <div class="workspace-grid">
        <div class="workspace-main">
            <CollapsiblePageSection SectionId="@WorkspaceSections.StageIngestionTranslation"
                                    Title="Ingestion & Translation"
                                    StatusLabel="@GetStageStatus(IngestionStage.IngestionTranslation)"
                                    StatusCssClass="@GetStageCss(IngestionStage.IngestionTranslation)">
                <IngestionTranslationPanel Result="WorkspaceState.Progress?.IngestionTranslation" />
            </CollapsiblePageSection>

            <CollapsiblePageSection SectionId="@WorkspaceSections.StageMetadataLinking"
                                    Title="Metadata & Linking"
                                    StatusLabel="@GetStageStatus(IngestionStage.MetadataLinking)"
                                    StatusCssClass="@GetStageCss(IngestionStage.MetadataLinking)">
                <MetadataLinkingPanel Result="WorkspaceState.Progress?.MetadataLinking" />
                <RetrievalSummaryCard Events="WorkspaceState.Progress?.RetrievalTrace" />
            </CollapsiblePageSection>

            <CollapsiblePageSection SectionId="@WorkspaceSections.StageIngestionHitl"
                                    Title="Knowledge Curator"
                                    StatusLabel="@GetHitlStatus()"
                                    StatusCssClass="@(WorkspaceState.CanSubmitDecision ? "status-warning" : "status-neutral")">
                <HumanReviewPanel Title="Knowledge Curator — approve before Vector DB write"
                                  Description="Review normalized and linked content before it is embedded and saved to the Vector DB."
                                  Decision="WorkspaceState.Progress?.HumanDecision"
                                  CanSubmit="WorkspaceState.CanSubmitDecision"
                                  IsBusy="WorkspaceState.IsBusy"
                                  OnSubmit="SubmitDecisionAsync" />
            </CollapsiblePageSection>
        </div>

        <aside class="workspace-side">
            <StudySummaryCard Study="WorkspaceState.Progress?.Study ?? _fallbackStudy" />
            <div class="card">
                <h3 class="card-title">Source material from Microsoft Fabric</h3>
                <KnowledgeSourceList Sources="WorkspaceState.Documents?.Sources ?? []" />
            </div>
            @if (WorkspaceState.Progress is not null)
            {
                <WorkflowTimeline Steps="BackendWorkflowMapper.BuildIngestionTimeline(WorkspaceState.Progress)" />
            }
            <div class="card vector-db-note">
                <p>On approval, curated knowledge is embedded and persisted to the <strong>Vector DB</strong>. Query workflows read from the Vector DB independently.</p>
            </div>
        </aside>
    </div>
}

@code {
    [Parameter] public string StudyId { get; set; } = string.Empty;
    [Parameter] public string? ExecutionId { get; set; }

    private bool _navigating;
    private string? _studyTitle;
    private StudySummary? _fallbackStudy;

    protected override async Task OnInitializedAsync()
    {
        WorkspaceState.OnChange += StateHasChanged;
        SectionState.ResetForResource(StudyId);
        await ReloadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (WorkspaceState.StudyId != StudyId || WorkspaceState.ExecutionId != ExecutionId)
        {
            SectionState.ResetForResource(StudyId);
            await ReloadAsync();
        }
    }

    protected override void OnParametersSet()
    {
        _fallbackStudy = Catalog.GetScenarioByStudyId(StudyId, WorkflowBlock.Ingestion)?.Study
            ?? new StudySummary(StudyId, StudyId, "—", "—", "—", ["Microsoft Fabric"]);
        _studyTitle = _fallbackStudy.Title;
    }

    private async Task ReloadAsync() => await WorkspaceState.LoadAsync(StudyId, ExecutionId);

    private async Task StartWorkflowAsync()
    {
        await WorkspaceState.StartWorkflowAsync();
        if (!string.IsNullOrWhiteSpace(WorkspaceState.ExecutionId))
        {
            Navigation.NavigateTo($"/ingestion/{StudyId}/{WorkspaceState.ExecutionId}", replace: true);
        }
    }

    private async Task SubmitDecisionAsync((bool Approved, string? Notes) decision) =>
        await WorkspaceState.SubmitDecisionAsync(decision.Approved, decision.Notes);

    private string? GetStageStatus(IngestionStage stage)
    {
        var current = WorkspaceState.Progress?.CurrentStage;
        if (current is null) return null;
        if (current > stage || current == IngestionStage.Completed) return "Completed";
        if (current == stage) return WorkspaceState.Progress?.Status == WorkflowStatus.Running ? "In progress" : null;
        return "Pending";
    }

    private string GetStageCss(IngestionStage stage)
    {
        var label = GetStageStatus(stage);
        return label switch
        {
            "Completed" => "status-success",
            "In progress" => "status-info",
            _ => "status-neutral"
        };
    }

    private string? GetHitlStatus() => WorkspaceState.CanSubmitDecision ? "Action required" : WorkspaceState.Progress?.HumanDecision is not null ? "Decided" : null;

    private async Task GoHome()
    {
        _navigating = true;
        Navigation.NavigateTo("/");
        await Task.Delay(300);
        _navigating = false;
    }

    public async ValueTask DisposeAsync()
    {
        WorkspaceState.OnChange -= StateHasChanged;
        await WorkspaceState.DisposeAsync();
    }
}
