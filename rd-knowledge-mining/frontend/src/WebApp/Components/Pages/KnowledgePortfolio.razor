@page "/"
@rendermode InteractiveServer
@inject KnowledgePortfolioState PortfolioState
@inject KnowledgeSessionStore SessionStore
@inject IRdKnowledgeApiClient ApiClient
@inject NavigationManager Navigation
@implements IDisposable

<PageTransitionLoader Visible="_navigating" Blocking="true" Message="Opening workspace…" />

<PageMasthead Kicker="HLS Agentic R&amp;D Knowledge Mining"
              Title="Knowledge Portfolio"
              Subtitle="Two independent blocks — ingestion reads Microsoft Fabric and writes to Vector DB; querying reads Vector DB at any time." />

@if (PortfolioState.IsLoading)
{
    <LoadingBlock Message="Loading portfolio…" />
}
else if (!string.IsNullOrWhiteSpace(PortfolioState.Error))
{
    <ErrorState Message="@PortfolioState.Error" OnRetry="LoadAsync" />
}
else
{
    <PageSection Title="Knowledge store" Subtitle="Vector DB — shared bridge between Block 1 and Block 2">
        <VectorDbSummaryCard Summary="PortfolioState.VectorDbSummary" />
    </PageSection>

    <PageSection Title="Ingestion scenarios" Subtitle="Ingestion & Translation → Metadata & Linking (Vector DB) → Knowledge Curator">
        <div class="picker-grid">
            <ScenarioPickerPanel Scenarios="PortfolioState.IngestionScenarios"
                                 @bind-SelectedScenarioId="_selectedIngestionId" />
            <ScenarioPreviewPanel Scenario="_selectedIngestion"
                                  IsSelected="_selectedIngestion is not null"
                                  IsRunning="_navigating"
                                  RunButtonLabel="Run ingestion"
                                  OnRun="RunIngestionAsync" />
        </div>
    </PageSection>

    <PageSection Title="Query scenarios" Subtitle="Search & Chat (interactive) → Curate on demand → Compliance Reviewer (reads from Vector DB)">
        <div class="picker-grid">
            <ScenarioPickerPanel Scenarios="PortfolioState.QueryScenarios"
                                 @bind-SelectedScenarioId="_selectedQueryId" />
            <ScenarioPreviewPanel Scenario="_selectedQuery"
                                  IsSelected="_selectedQuery is not null"
                                  IsRunning="_navigating"
                                  RunButtonLabel="Run query"
                                  OnRun="RunQueryAsync" />
        </div>
    </PageSection>

    <PageSection Title="Active sessions" Subtitle="Workspaces opened in this browser session">
        <RecentSessionsList Sessions="PortfolioState.ActiveSessions" OnOpen="OpenSessionAsync" />
    </PageSection>
}

@code {
    private string? _selectedIngestionId;
    private string? _selectedQueryId;
    private bool _navigating;

    private SeedScenarioDefinition? _selectedIngestion =>
        PortfolioState.IngestionScenarios.FirstOrDefault(s => s.ScenarioId == _selectedIngestionId)
        ?? PortfolioState.IngestionScenarios.FirstOrDefault();

    private SeedScenarioDefinition? _selectedQuery =>
        PortfolioState.QueryScenarios.FirstOrDefault(s => s.ScenarioId == _selectedQueryId)
        ?? PortfolioState.QueryScenarios.FirstOrDefault();

    protected override async Task OnInitializedAsync()
    {
        PortfolioState.OnChange += OnPortfolioChanged;
        await LoadAsync();
        EnsureDefaultSelections();
    }

    private void OnPortfolioChanged()
    {
        EnsureDefaultSelections();
        StateHasChanged();
    }

    private void EnsureDefaultSelections()
    {
        if (_selectedIngestionId is null ||
            PortfolioState.IngestionScenarios.All(s => !s.ScenarioId.Equals(_selectedIngestionId, StringComparison.OrdinalIgnoreCase)))
        {
            _selectedIngestionId = PortfolioState.IngestionScenarios.FirstOrDefault()?.ScenarioId;
        }

        if (_selectedQueryId is null ||
            PortfolioState.QueryScenarios.All(s => !s.ScenarioId.Equals(_selectedQueryId, StringComparison.OrdinalIgnoreCase)))
        {
            _selectedQueryId = PortfolioState.QueryScenarios.FirstOrDefault()?.ScenarioId;
        }
    }

    private async Task LoadAsync() => await PortfolioState.LoadAsync();

    private async Task RunIngestionAsync()
    {
        if (_selectedIngestion is null) return;
        _navigating = true;
        SessionStore.OpenIngestionSession(_selectedIngestion.StudyId, _selectedIngestion.Title, _selectedIngestion.ScenarioId);
        PortfolioState.RefreshSessions();
        Navigation.NavigateTo($"/ingestion/{_selectedIngestion.StudyId}");
        await Task.Delay(300);
        _navigating = false;
    }

    private async Task RunQueryAsync()
    {
        if (_selectedQuery is null) return;
        _navigating = true;
        try
        {
            var sessionId = $"query-{_selectedQuery.ScenarioId}";
            var response = await ApiClient.StartQueryWorkflowAsync(sessionId);
            SessionStore.OpenQuerySession(
                sessionId,
                response.ExecutionId,
                _selectedQuery.Title,
                _selectedQuery.StudyId,
                _selectedQuery.SampleQuestion ?? string.Empty,
                _selectedQuery.ScenarioId);
            PortfolioState.RefreshSessions();
            Navigation.NavigateTo($"/query/{sessionId}/{response.ExecutionId}");
        }
        finally
        {
            await Task.Delay(300);
            _navigating = false;
        }
    }

    private async Task OpenSessionAsync(KnowledgeSessionSummary session)
    {
        _navigating = true;
        var url = session.Block == WorkflowBlock.Ingestion
            ? string.IsNullOrWhiteSpace(session.ExecutionId)
                ? $"/ingestion/{session.SessionId}"
                : $"/ingestion/{session.SessionId}/{session.ExecutionId}"
            : string.IsNullOrWhiteSpace(session.ExecutionId)
                ? $"/query/{session.SessionId}"
                : $"/query/{session.SessionId}/{session.ExecutionId}";
        Navigation.NavigateTo(url);
        await Task.Delay(300);
        _navigating = false;
    }

    public void Dispose() => PortfolioState.OnChange -= OnPortfolioChanged;
}
