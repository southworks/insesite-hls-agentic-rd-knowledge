<button type="button" class="@CssClass" disabled="@(Disabled || IsLoading)" @onclick="HandleClick">
    @if (IsLoading)
    {
        <span class="spinner spinner-sm" aria-hidden="true"></span>
        <span>@LoadingText</span>
    }
    else
    {
        @ChildContent
    }
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string LoadingText { get; set; } = "Working…";
    [Parameter] public string CssClass { get; set; } = "btn btn-primary";

    private async Task HandleClick() => await OnClick.InvokeAsync();
}
